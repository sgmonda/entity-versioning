{
  "version": "0.1.1",
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env --allow-write main.ts",
    "test": "deno test --allow-net --allow-read --allow-env --allow-write",
    "test:unit": "deno test --allow-read --allow-env tests/core/",
    "test:integration": "deno test --allow-net --allow-read --allow-env --allow-write tests/connectors/",
    "compile": "deno compile --allow-net --allow-read --allow-env --allow-write --output out/ev main.ts",
    "demo": "deno run --allow-net --allow-read --allow-env --allow-write --allow-run demo/playground.ts",
    "demo:reset": "deno run --allow-net --allow-read --allow-env --allow-write --allow-run demo/playground.ts --reset",
    "test:mysql": "deno test --allow-net --allow-read --allow-env --allow-write tests/connectors/mysql/"
  },
  "imports": {
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@cliffy/command": "jsr:@cliffy/command@^1",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1",
    "postgres": "npm:postgres@^3",
    "mysql2": "npm:mysql2@^3"
  }
}
